[general]
	downloadScheme = anonymous http
	changesPerPage = 10
	signedOffBy = true
	defaultBaseForMerges = auto merge
	publishCommentsOnPush = true
	workInProgressByDefault = true
[diff]
	ignoreWhitespace = ignore leading and trailing
[my "Changes"]
	url = "#/dashboard/self"
[my "Draft Comments"]
	url = "#/q/has:draft"
[my "Edits"]
	url = "#/q/has:edit"
[my "Watched Changes"]
	url = "#/q/is:watched+is:open"
[my "Starred Changes"]
	url = "#/q/is:starred"
[my "Groups"]
	url = "#/settings/#Groups"
[edit]
	lineWrapping = true
	indentWithTabs = true
	autoCloseBrackets = true
