[general]
	signedOffBy = true
	emailStrategy = cc on own comments
	publishCommentsOnPush = true
	workInProgressByDefault = true
	legacycidInChangeTable = true
	downloadScheme = http
[edit]
	lineWrapping = true
	indentWithTabs = true
	autoCloseBrackets = true
[changeTable]
	column = Subject
	column = Status
	column = Owner
	column = Assignee
	column = Repo
	column = Branch
	column = Updated
	column = Size
[my "Changes"]
	url = /dashboard/self
[my "Draft Comments"]
	url = /q/has:draft
[my "Edits"]
	url = /q/has:edit
[my "Watched Changes"]
	url = /q/is:watched+is:open
[my "Starred Changes"]
	url = /q/is:starred
[my "Groups"]
	url = "/settings/#Groups"
