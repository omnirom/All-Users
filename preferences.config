[general]
	downloadScheme = ssh
[my "Changes"]
	url = "#/dashboard/self"
[my "Drafts"]
	url = "#/q/owner:self+is:draft"
[my "Draft Comments"]
	url = "#/q/has:draft"
[my "Edits"]
	url = "#/q/has:edit"
[my "Watched Changes"]
	url = "#/q/is:watched+is:open"
[my "Starred Changes"]
	url = "#/q/is:starred"
[my "Groups"]
	url = "#/groups/self"
