[general]
	diffView = unified diff
	emailStrategy = cc on own comments
	emailFormat = plaintext
	defaultBaseForMerges = auto merge
[my "Changes"]
	url = /dashboard/self
[my "Draft Comments"]
	url = /q/has:draft
[my "Edits"]
	url = /q/has:edit
[my "Watched Changes"]
	url = /q/is:watched+is:open
[my "Starred Changes"]
	url = /q/is:starred
[my "Groups"]
	url = "/settings/#Groups"
