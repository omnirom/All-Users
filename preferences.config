[general]
	signedOffBy = true
	downloadScheme = ssh
	expandInlineDiffs = true
	publishCommentsOnPush = true
[diff]
	lineWrapping = true
[changeTable]
	column = Subject
	column = Status
	column = Owner
	column = Assignee
	column = Project
	column = Branch
	column = Updated
	column = Size
	column = Size
[my "Changes"]
	url = "#/dashboard/self"
[my "Draft Comments"]
	url = "#/q/has:draft"
[my "Edits"]
	url = "#/q/has:edit"
[my "Watched Changes"]
	url = "#/q/is:watched+is:open"
[my "Starred Changes"]
	url = "#/q/is:starred"
[my "Groups"]
	url = "#/groups/self"
